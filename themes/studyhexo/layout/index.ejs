<!-- 引入样式文件 -->
<%- css('css/index') %>
<div class="home">
    <ul class="left">
        <% site.posts.forEach(function(item) { %>
            <li class="home-item">
                <a href="<%- item.path %>" class="home-item-container">
                    <% if ( item.cover ) { %>
                        <img src="<%= url_for(item.path+item.cover) %>" alt="封面图片"/>
                    <% } %>
                    <div class="home-left">
                        <div class="home-head">
                            <div class="home-title"><%= item.title %></div>
                            <div class="home-head-smalltag">
                                <div class="home-author" style="margin-right: 10px;"><%= theme.author %></div>
                                <div class="home-date"><%= date(item.date, "YYYY-MM-DD") %></div>
                            </div>
                        </div>
                        <div class="home-abstract"><%= item.description %></div>
                        <div class="home-footer">这个分类稍后研究一下</div>
                    </div>
                </a>
            </li>
        <% }); %>
    </ul>
    <div class="right">
        <div class="right-div"><%- include("author.ejs") %></div>
    </div>
</div>